{
  "name": "gws-cli",
  "description": "npm installer for gws-cli — a community-maintained fork of the Google Workspace CLI",
  "version": "0.24.0",
  "license": "Apache-2.0",
  "author": "Justin Poehnelt",
  "repository": {
    "type": "git",
    "url": "https://github.com/CruGlobal/gws-cli.git"
  },
  "homepage": "https://github.com/CruGlobal/gws-cli",
  "bugs": {
    "url": "https://github.com/CruGlobal/gws-cli/issues"
  },
  "bin": {
    "gws": "run.js"
  },
  "scripts": {
    "postinstall": "node install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "preferUnplugged": true,
  "keywords": [
    "cli",
    "google-workspace",
    "google",
    "google-api",
    "google-drive",
    "google-gmail",
    "google-sheets",
    "google-calendar",
    "google-docs",
    "google-chat",
    "google-admin",
    "gsuite",
    "discovery-api",
    "ai-agent",
    "agent-skills",
    "automation",
    "oauth2",
    "rust"
  ],
  "supportedPlatforms": {
    "aarch64-apple-darwin": {
      "artifact": "gws-aarch64-apple-darwin.tar.gz",
      "binary": "gws"
    },
    "x86_64-apple-darwin": {
      "artifact": "gws-x86_64-apple-darwin.tar.gz",
      "binary": "gws"
    },
    "aarch64-unknown-linux-gnu": {
      "artifact": "gws-aarch64-unknown-linux-gnu.tar.gz",
      "binary": "gws"
    },
    "aarch64-unknown-linux-musl": {
      "artifact": "gws-aarch64-unknown-linux-musl.tar.gz",
      "binary": "gws"
    },
    "x86_64-unknown-linux-gnu": {
      "artifact": "gws-x86_64-unknown-linux-gnu.tar.gz",
      "binary": "gws"
    },
    "x86_64-unknown-linux-musl": {
      "artifact": "gws-x86_64-unknown-linux-musl.tar.gz",
      "binary": "gws"
    },
    "x86_64-pc-windows-msvc": {
      "artifact": "gws-x86_64-pc-windows-msvc.zip",
      "binary": "gws.exe"
    }
  }
}
